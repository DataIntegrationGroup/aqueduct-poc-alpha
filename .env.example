# Copy to .env and adjust for local use: cp .env.example .env

POSTGRES_PASSWORD=anything
POSTGRES_USER=sensorthings_example
POSTGRES_DB=sensorthings_example
FROST_SERVICE_ROOT_URL=http://localhost:8080/FROST-Server

# ── HydroVu API (pvacd_ingest) ────────────────────────────────────────────────
HYDROVU_CLIENT_ID=your-client-id
HYDROVU_CLIENT_SECRET=your-client-secret
# Public endpoints — defaults baked into settings, override only if needed
#HYDROVU_TOKEN_URL=https://www.hydrovu.com/public-api/oauth/token
#HYDROVU_API_BASE_URL=https://www.hydrovu.com/public-api/v1

# ── GCS raw zone ──────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-bucket-name
# Auth via ADC: gcloud auth application-default login
# (or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json)

# ── Ingest window ─────────────────────────────────────────────────────────────
# Default daily window; override per request with lookback_days / start_date
PVACD_LOOKBACK_DAYS=1
